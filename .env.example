PORT=8080
PUBLIC_BASE_URL=http://127.0.0.1:8080

# Optional: fill these to create real payOS payment links.
# Without them, the app uses the built-in mock checkout for testing.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Optional but recommended for durable storage on free hosting.
# Use the service role key only on the server. Do not expose it in frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: send ticket emails when a registration is confirmed.
# Option A: generic HTTP email API. Preferred if your business already has an email service.
EMAIL_API_URL=
EMAIL_API_KEY=
EMAIL_API_AUTH_HEADER=Authorization
EMAIL_API_AUTH_SCHEME=Bearer
EMAIL_API_FROM=

# Option B: SMTP fallback.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
